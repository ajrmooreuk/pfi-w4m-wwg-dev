    "createdBy": "claude-opus-4.6",
    "description": "Generates PRDs with Epic-Feature-Story hierarchies from Terms of Reference and VSOM context. Follows EFS-ONT v2.0.0 lineage specification with 5-layer traceability (VSOM→OKR/KPI→VP→ICP→EFS). Outputs GitHub-ready issue creation scripts.",
    "tags": [
      "efs",
      "prd",
      "epic",
      "feature",
      "story",
      "agile",
      "lineage",
      "vsom",
      "github-issues",
      "skill-standalone"
    ]
  },
  "artifactDefinition": {
    "skillType": "SKILL_STANDALONE",
    "dtreeClassification": {
      "autonomy": 4,
      "orchestration": "none",
      "bundling": 3,
      "recommendation": "SKILL_STANDALONE"
    },
    "technology": {
      "runtime": "claude-code-cli",
      "format": "SKILL.md",
      "allowedTools": ["Bash(gh *)", "Read", "Grep", "Glob", "Write"]
    },
    "capabilities": [
      {
        "name": "Context Ingestion",
        "description": "Reads ToR, VSOM context, VP briefs, or existing PRDs and extracts structured context"
      },
      {
        "name": "5-Layer Lineage Mapping",
        "description": "Maps context to VSOM→OKR/KPI→VP→ICP→EFS lineage with VP-RRR alignment"
      },
      {
        "name": "Epic Decomposition",
        "description": "Decomposes scope into MECE epics with business outcomes and VSOM traceability"
      },
      {
        "name": "Feature Breakdown",
        "description": "Breaks epics into functional capabilities with acceptance criteria"
      },
      {
        "name": "User Story Generation",
        "description": "Generates As/Want/SoThat stories with INVEST criteria and RRR alignment"
      },
      {
        "name": "PRD Assembly",
        "description": "Assembles full PRD document from EFS-PRD template"
      },
      {
        "name": "GitHub Issue Generation",
        "description": "Generates gh CLI commands for epic/feature/story issues with auto-numbering"
      }
    ],
    "qualityGates": [
      { "id": "G1", "name": "Context Completeness", "section": 1 },
      { "id": "G2", "name": "Strategic Traceability", "section": 2 },
      { "id": "G3", "name": "Epic Alignment", "section": 3 },
